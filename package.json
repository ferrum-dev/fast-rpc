{
  "name": "fast-rpc",
  "version": "1.0.1",
  "description": "Customizable Discord RPC Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w"
  },
  "keywords": [
    "discord",
    "rpc"
  ],
  "author": "ferrum-dev (Fast RPC)",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.ferrum.fastrpc",
    "productName": "Fast RPC Manager",
    "icon": "logo/logo.png",
    "win": {
      "icon": "logo/logo.png",
      "target": "nsis",
      "artifactName": "${productName} Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ferrum-dev",
        "repo": "fast-rpc"
      }
    ]
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}